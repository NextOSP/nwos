#!/usr/bin/make -f
export DH_VERBOSE=1
export PYBUILD_NAME=nwos-bin
export PYBUILD_DISABLE=test

%:
	dh ${@} --with=python3 --buildsystem=pybuild

override_dh_auto_build:
	cp -r addons/* nwos/addons/
	dh_auto_build

override_dh_auto_install:
	dh_auto_install
	rm debian/nwos/usr/lib/python3*/dist-packages/nwos/addons/point_of_sale/static/src/fonts/Inconsolata.otf
	for LINKTARGET in `awk '{ print $2 }' nwos.links`; do rm debian/nwos/${LINKTARGET} ; done
	find debian/nwos -name LICENSE.txt -exec rm {} \;

override_dh_auto_clean:
	dh_auto_clean
	for d in addons/* ; do rm -fr nwos/$$d ; done
