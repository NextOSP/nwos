<?xml version="1.0" encoding="utf-8"?>
<nwos>
    <record id="helpdesk_ticket_form_rfid" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.rfid</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.view_helpdesk_ticket_form"/>
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field name="rfid_site_id"/>
                <field name="rfid_sale_order_id" readonly="1"/>
                <field name="rfid_project_id" readonly="1"/>
                <field name="rfid_activation_date" readonly="1"/>
                <field name="rfid_installed_lot_ids" widget="many2many_tags" readonly="1"/>
            </field>
        </field>
    </record>
</nwos>
