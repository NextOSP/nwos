<?xml version="1.0" encoding="utf-8"?>
<nwos>
    <record id="res_groups_privilege_rfid" model="res.groups.privilege">
        <field name="name">Nextwaves Kit</field>
        <field name="sequence">55</field>
        <field name="category_id" ref="base.module_category_services"/>
    </record>

    <record id="group_rfid_user" model="res.groups">
        <field name="name">User</field>
        <field name="comment">Can operate Nextwaves Kit sales, deliveries, installations and subscriptions.</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_rfid"/>
        <field name="implied_ids" eval="[(4, ref('project.group_project_user')), (4, ref('helpdesk.group_helpdesk_user')), (4, ref('sales_team.group_sale_salesman')), (4, ref('stock.group_stock_user'))]"/>
    </record>

    <record id="group_rfid_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="comment">Can configure and manage all Nextwaves Kit operations and billing.</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_rfid"/>
        <field name="implied_ids" eval="[(4, ref('nwos_rfid_service.group_rfid_user')), (4, ref('project.group_project_manager')), (4, ref('helpdesk.group_helpdesk_manager'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <data noupdate="1">
        <record id="rfid_site_company_rule" model="ir.rule">
            <field name="name">Nextwaves Kit sites: multi-company</field>
            <field name="model_id" ref="model_rfid_service_site"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
        <record id="rfid_subscription_company_rule" model="ir.rule">
            <field name="name">Nextwaves Kit subscriptions: multi-company</field>
            <field name="model_id" ref="model_rfid_subscription"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
        <record id="rfid_subscription_period_company_rule" model="ir.rule">
            <field name="name">Nextwaves Kit billing periods: multi-company</field>
            <field name="model_id" ref="model_rfid_subscription_period"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</nwos>
