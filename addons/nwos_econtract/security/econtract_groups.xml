<?xml version="1.0" encoding="utf-8"?>
<nwos>
    <record id="module_category_econtract" model="ir.module.category">
        <field name="name">eContract</field>
        <field name="sequence">20</field>
    </record>

    <record id="res_groups_privilege_econtract" model="res.groups.privilege">
        <field name="name">eContract</field>
        <field name="sequence">20</field>
        <field name="category_id" ref="module_category_econtract"/>
    </record>

    <record id="group_econtract_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="res_groups_privilege_econtract"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_econtract_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_econtract"/>
        <field name="implied_ids" eval="[(4, ref('group_econtract_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</nwos>
