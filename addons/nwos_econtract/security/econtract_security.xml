<?xml version="1.0" encoding="utf-8"?>
<nwos>
    <data noupdate="1">
        <record id="econtract_contract_rule_portal" model="ir.rule">
            <field name="name">Portal: own contracts</field>
            <field name="model_id" ref="model_econtract_contract"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('partner_id', 'child_of', user.commercial_partner_id.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="econtract_contract_rule_company" model="ir.rule">
            <field name="name">eContract: multi-company</field>
            <field name="model_id" ref="model_econtract_contract"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</nwos>
