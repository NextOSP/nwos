<?xml version="1.0" encoding="utf-8" ?>
<nwos>

    <!-- NWOS19: the delivery radio (`website_sale.delivery_method`) already renders
         `t-att-data-delivery-type`, so the former `checkout_delivery` override of the
         removed `website_sale.payment_delivery_methods` template is no longer needed. -->

    <template id="payment_method_form" inherit_id="payment.method_form">
        <xpath expr="//input[@name='o_payment_radio']" position="attributes">
            <attribute name="t-att-data-is-onsite">1 if provider_sudo.custom_mode == 'onsite' else 0</attribute>
        </xpath>
    </template>

    <!-- NWOS19: `payment_confirmation_status` was restructured (no more `card-body`).
         Append the on-site pickup message to the order confirmation block. -->
    <template id="payment_confirmation_status" inherit_id="website_sale.payment_confirmation_status">
        <xpath expr="//div[@name='order_confirmation']" position="inside">
            <t t-if="tx_sudo and tx_sudo.provider_id.custom_mode == 'onsite'">
                <div class="o_header_carrier_message mt-2">
                    <b t-out="order.carrier_id.name"/><span class="text-muted"> (On site picking)</span>
                </div>
                <div class="o_body_carrier_message">
                    <t t-out="order.carrier_id.website_description"/>
                </div>
            </t>
        </xpath>
    </template>

</nwos>
