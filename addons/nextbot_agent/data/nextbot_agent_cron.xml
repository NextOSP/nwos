<?xml version="1.0" encoding="utf-8"?>
<nwos>
    <record id="ir_cron_process_nextbot_runs" model="ir.cron">
        <field name="name">NextBot: process queued agent runs</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="model_id" ref="model_nextbot_run"/>
        <field name="code">model._cron_process_queued_runs()</field>
        <field name="state">code</field>
    </record>
    <record id="ir_cron_process_nextbot_steps_1" model="ir.cron">
        <field name="name">NextBot: read worker 1</field>
        <field name="interval_number">1</field>
        <field name="interval_type">minutes</field>
        <field name="model_id" ref="model_nextbot_run_step"/>
        <field name="code">model._cron_process_ready_steps()</field>
        <field name="state">code</field>
    </record>
    <record id="ir_cron_process_nextbot_steps_2" model="ir.cron">
