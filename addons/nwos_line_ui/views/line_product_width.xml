<?xml version="1.0" encoding="utf-8"?>
<nwos>
    <data>

        <!-- Purchase Order lines: widen the Product column so names aren't truncated. -->
        <record id="purchase_order_form_product_width" model="ir.ui.view">
            <field name="name">purchase.order.form.product.width</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']/list/field[@name='product_id']" position="attributes">
                    <attribute name="width">300</attribute>
                </xpath>
            </field>
        </record>

        <!-- Sales Order / Quotation lines: widen the Product column. -->
        <record id="sale_order_form_product_width" model="ir.ui.view">
            <field name="name">sale.order.form.product.width</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="attributes">
                    <attribute name="width">300</attribute>
                </xpath>
            </field>
        </record>

        <!-- Customer Invoice / Vendor Bill lines: widen the Product column. -->
        <record id="account_move_form_product_width" model="ir.ui.view">
            <field name="name">account.move.form.product.width</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='product_id']" position="attributes">
                    <attribute name="width">300</attribute>
                </xpath>
            </field>
        </record>

    </data>
</nwos>
