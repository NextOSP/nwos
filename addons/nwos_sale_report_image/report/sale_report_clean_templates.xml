<?xml version="1.0" encoding="utf-8"?>
<nwos>

    <!--
        "Quotation (Clean)" - a self-contained, modern quotation layout tuned for
        Vietnamese business documents (letterhead, centered title, customer /
        quotation info, product table with UoM column, totals, amount in words,
        standard terms, bank details, signature blocks). It does NOT use
        web.external_layout: it renders its own page header/footer via the
        .header / .article / .footer convention that the PDF engine extracts
        (see ir_actions_report._prepare_html).

        Rendered by wkhtmltopdf 0.12.6 (patched Qt / old WebKit): layout is
        table-based with explicit widths and inline styles - no flexbox / grid.

        Design follows IBM Carbon but restrained: ink text (#161616) with grey
        rules; the accent blue (#0f62fe) is used ONLY as the note-box bar. No
        boxed cards - sections are separated by whitespace and thin rules. Pass
        show_images=True (see report_saleorder_image) to add product thumbnails.
    -->
    <template id="report_saleorder_clean_document">
        <t t-set="doc" t-value="doc.with_context(lang=env.context.get('report_lang') or doc.partner_id.lang)"/>
        <t t-set="is_quotation" t-value="doc.state in ('draft', 'sent')"/>
        <!-- Set by report_saleorder_image (via record context) to show product
             thumbnails; absent (falsy) for the plain Quotation. -->
        <t t-set="show_images" t-value="doc.env.context.get('show_images') or False"/>
        <!-- Set by report_saleorder_proforma_clean to title the doc "Pro-forma
             Invoice" while reusing this exact layout. -->
        <t t-set="proforma" t-value="doc.env.context.get('proforma') or False"/>

        <!-- Reset the report/preview table borders and draw only ours. Emitted
             into each of header/article/footer since the PDF engine renders them
             as separate documents. -->
        <t t-set="nw_style">
            <style>
                .o_nw { font-family: 'Noto Sans', 'DejaVu Sans', Arial, sans-serif; color: #161616; -webkit-print-color-adjust: exact; }
                /* Nuclear border reset. Bootstrap Reboot (pulled in by
                   web.report_assets_common) sets `border-style: solid;
                   border-width: 0` on table, thead, tbody, tfoot, tr, td, th -
                   which wkhtmltopdf's old WebKit renders as visible hairlines
                   even at width 0 (modern Chrome does not, so the on-screen
                   preview looked fine while the PDF was boxed). We must override
                   border-STYLE (not just width) on ALL of those elements. Our
                   own rules below use higher specificity + !important, so the
                   borders we DO want survive. */
                /* wkhtmltopdf's old WebKit draws Bootstrap Reboot's
                   `border-style: solid; border-width: 0` as hairline boxes and
                   ignores border overrides on border-collapse:collapse tables.
                   Using border-collapse: separate + border-spacing: 0 makes each
                   cell honor its OWN (reset) border, killing the boxes while our
                   explicit border-bottom/top rules below still render as lines. */
                .o_nw table { border-collapse: separate !important; border-spacing: 0 !important; }
                .o_nw table, .o_nw thead, .o_nw tbody, .o_nw tfoot, .o_nw tr, .o_nw td, .o_nw th {
                    border: 0 none !important; border-width: 0 !important; border-style: none !important;
                }
                .o_nw td, .o_nw th { vertical-align: top; }
                .o_nw .o_nw_muted { color: #525252 !important; }
                .o_nw .o_nw_label { color: #525252 !important; font-size: 8.5px; text-transform: uppercase; letter-spacing: .4px; }
                .o_nw .o_nw_rule { border-bottom: 1px solid #e0e0e0 !important; }
                .o_nw .o_nw_sect { border-bottom: 1px solid #161616 !important; }
                .o_nw .o_nw_products thead &gt; tr &gt; th { background: #e0e0e0 !important; color: #161616 !important; border-bottom: 1px solid #c6c6c6 !important; }
                .o_nw .o_nw_products tbody &gt; tr &gt; td { border-bottom: 1px solid #e0e0e0 !important; }
                .o_nw .o_nw_grand &gt; td { border-top: 2px solid #161616 !important; }
                .o_nw .o_nw_band { background: #edf5ff !important; border-left: 3px solid #0f62fe !important; }
                .o_nw .o_nw_signline &gt; td { border-top: 1px solid #8d8d8d !important; }
                .o_nw .o_nw_avoid { page-break-inside: avoid; }
            </style>
        </t>

        <!-- ================= Document body ================= -->
        <div class="article o_nw"
             t-att-data-oe-model="doc._name"
             t-att-data-oe-id="doc.id"
             t-att-data-oe-lang="doc.env.context.get('lang')">
            <t t-out="nw_style"/>

            <!-- 1. Company letterhead (inline, renders in full on page 1) -->
            <table style="width: 100%; margin-bottom: 14px;">
                <tr>
                    <td style="vertical-align: bottom;">
                        <div class="fw-bold" style="color: #161616; font-weight: 700; font-size: 17px; letter-spacing: .3px;"><span t-field="doc.company_id.name"/></div>
                        <div class="o_nw_muted" style="font-size: 9px; line-height: 1.55; margin-top: 2px;">
                            <div>
                                <span t-field="doc.company_id.partner_id"
                                      t-options='{"widget": "contact", "fields": ["address"], "no_marker": true}'/>
                            </div>
                            <div>
                                <t t-if="doc.company_id.phone">Tel: <span t-field="doc.company_id.phone"/></t>
                                <t t-if="doc.company_id.email"> · Email: <span t-field="doc.company_id.email"/></t>
                                <t t-if="doc.company_id.website"> · <span t-field="doc.company_id.website"/></t>
                            </div>
                            <div t-if="doc.company_id.vat">
                                Tax ID: <span t-field="doc.company_id.vat"/>
                            </div>
                        </div>
                    </td>
                    <td t-if="doc.company_id.logo" style="text-align: right; vertical-align: bottom; width: 28%;">
                        <img t-att-src="image_data_uri(doc.company_id.logo)" style="max-height: 62px; max-width: 100%;" alt="Logo"/>
                    </td>
                </tr>
            </table>

            <!-- 2. Title -->
            <div class="o_nw_sect" style="text-align: center; padding-bottom: 8px; margin-bottom: 16px;">
                <div style="color: #161616; font-weight: 300; font-size: 26px; letter-spacing: 1px; line-height: 1.1; text-transform: uppercase;">
                    <t t-if="proforma">Pro-forma Invoice</t>
                    <t t-elif="is_quotation">Quotation</t>
                    <t t-else="">Order</t>
                </div>
                <div class="o_nw_muted" style="font-size: 11px; margin-top: 3px;">
                    <span class="fw-bold" t-field="doc.name"/>
                    <t t-if="doc.date_order"> · <span t-field="doc.date_order" t-options='{"widget": "date"}'/></t>
                    <t t-if="doc.client_order_ref"> · <span t-field="doc.client_order_ref"/></t>
                </div>
            </div>

            <!-- 3. Customer (left) + quotation meta (right), borderless -->
            <table style="width: 100%; table-layout: fixed; margin-bottom: 18px;">
                <tr>
                    <td style="width: 48%; padding-right: 16px; vertical-align: top;">
                        <div class="o_nw_label o_nw_rule" style="padding-bottom: 3px; margin-bottom: 6px;">Customer</div>
                        <div class="fw-bold" style="font-size: 12px;"><span t-field="doc.partner_id.name"/></div>
                        <div class="o_nw_muted" style="line-height: 1.5; font-size: 11px;">
                            <span t-field="doc.partner_id"
                                  t-options='{"widget": "contact", "fields": ["address", "phone"], "no_marker": true}'/>
                        </div>
                        <div t-if="doc.partner_id.vat" style="font-size: 11px;">Tax ID: <span t-field="doc.partner_id.vat"/></div>
                        <t t-if="doc.partner_shipping_id and doc.partner_shipping_id != doc.partner_id">
                            <div class="o_nw_label" style="margin-top: 6px;">Delivery Address</div>
                            <div class="o_nw_muted" style="line-height: 1.5; font-size: 11px;">
                                <span t-field="doc.partner_shipping_id"
                                      t-options='{"widget": "contact", "fields": ["address", "phone"], "no_marker": true}'/>
                            </div>
                        </t>
                    </td>
                    <td style="width: 52%; vertical-align: top;">
                        <div class="o_nw_label o_nw_rule" style="padding-bottom: 3px; margin-bottom: 6px;">
                            <t t-if="is_quotation">Quotation Details</t>
                            <t t-else="">Order Details</t>
                        </div>
                        <table style="width: 100%; font-size: 11px;">
                            <tr>
                                <td style="padding: 2px 8px 5px 0; width: 50%;">
                                    <div class="o_nw_label">Quotation No.</div>
                                    <div class="fw-bold"><span t-field="doc.name"/></div>
                                </td>
                                <td style="padding: 2px 0 5px;">
                                    <div class="o_nw_label">Quotation Date</div>
                                    <div><span t-field="doc.date_order" t-options='{"widget": "date"}'/></div>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 2px 8px 5px 0;">
                                    <div class="o_nw_label">Valid Till</div>
                                    <div>
                                        <span t-if="doc.validity_date" t-field="doc.validity_date"/>
                                        <t t-else="">—</t>
                                    </div>
                                </td>
                                <td style="padding: 2px 0 5px;">
                                    <div class="o_nw_label">Prepared By</div>
                                    <div><span t-field="doc.user_id.name"/></div>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 2px 8px 0 0;">
                                    <div class="o_nw_label">Payment Terms</div>
                                    <div>
                                        <span t-if="doc.payment_term_id" t-field="doc.payment_term_id.name"/>
                                        <t t-else="">—</t>
                                    </div>
                                </td>
                                <td style="padding: 2px 0 0;">
                                    <div class="o_nw_label">Currency</div>
                                    <div><span t-field="doc.currency_id.name"/></div>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>

            <!-- 4. Products -->
            <table class="o_nw_products" style="width: 100%; font-size: 11px; margin-bottom: 14px;">
                <thead>
                    <tr>
                        <th style="width: 6%; padding: 7px 6px; text-align: center;">No.</th>
                        <th style="padding: 7px 6px; text-align: left;">Item &amp; Specification</th>
                        <th style="width: 10%; padding: 7px 6px; text-align: center;">UoM</th>
                        <th style="width: 10%; padding: 7px 6px; text-align: right;">Qty</th>
                        <th style="width: 16%; padding: 7px 6px; text-align: right;">Unit Price</th>
                        <th style="width: 18%; padding: 7px 6px; text-align: right;">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="idx" t-value="0"/>
                    <t t-foreach="doc.order_line" t-as="line">
                        <t t-if="line.display_type == 'line_section'">
                            <tr>
                                <td colspan="6" class="fw-bold" style="background: #f4f4f4; padding: 6px;">
                                    <span t-field="line.name"/>
                                </td>
                            </tr>
                        </t>
                        <t t-elif="line.display_type == 'line_note'">
                            <tr>
                                <td colspan="6" class="fst-italic o_nw_muted" style="padding: 5px 6px;">
                                    <span t-field="line.name"/>
                                </td>
                            </tr>
                        </t>
                        <t t-else="">
                            <t t-set="idx" t-value="idx + 1"/>
                            <tr>
                                <td style="padding: 7px 6px; text-align: center;" t-out="idx"/>
                                <td style="padding: 7px 6px;">
                                    <table style="width: 100%;">
                                        <tr>
                                            <td t-if="show_images and line.product_id.image_128"
                                                style="width: 66px; padding-right: 8px; vertical-align: top;">
                                                <img t-att-src="image_data_uri(line.product_id.image_128)"
                                                     style="max-height: 60px; max-width: 60px;" alt="Product"/>
                                            </td>
                                            <td style="vertical-align: top;">
                                                <div class="fw-bold"><span t-field="line.product_id.display_name"/></div>
                                                <t t-set="desc_lines" t-value="(line.name or '').split('\n')[1:]"/>
                                                <div t-if="desc_lines" class="o_nw_muted"
                                                     style="font-size: 10px; white-space: pre-line; margin-top: 1px;"
                                                     t-out="'\n'.join(desc_lines)"/>
                                            </td>
                                        </tr>
                                    </table>
                                </td>
                                <td style="padding: 7px 6px; text-align: center;" class="text-nowrap">
                                    <span t-field="line.product_uom_id"/>
                                </td>
                                <td style="padding: 7px 6px; text-align: right;" class="text-nowrap">
                                    <span t-field="line.product_uom_qty"/>
                                </td>
                                <td style="padding: 7px 6px; text-align: right;" class="text-nowrap">
                                    <span t-field="line.price_unit"
                                          t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                                <td style="padding: 7px 6px; text-align: right;" class="text-nowrap fw-bold">
                                    <span t-field="line.price_subtotal"
                                          t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                            </tr>
                        </t>
                    </t>
                </tbody>
            </table>

            <!-- 5. Totals (right-aligned via table for wkhtmltopdf) -->
            <table style="width: 100%;" class="o_nw_avoid">
                <tr>
                    <td style="width: 56%;"/>
                    <td style="width: 44%;">
                        <table style="width: 100%; font-size: 11px;">
                            <tr>
                                <td style="padding: 3px 6px;">Subtotal</td>
                                <td style="padding: 3px 6px; text-align: right;" class="text-nowrap">
                                    <span t-field="doc.amount_untaxed"
                                          t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                            </tr>
                            <tr t-if="doc.amount_tax">
                                <td style="padding: 3px 6px;">Taxes</td>
                                <td style="padding: 3px 6px; text-align: right;" class="text-nowrap">
                                    <span t-field="doc.amount_tax"
                                          t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                            </tr>
                            <tr class="o_nw_grand">
                                <td class="fw-bold" style="padding: 6px; font-size: 12px;">Grand Total</td>
                                <td class="text-nowrap fw-bold" style="padding: 6px; text-align: right; font-size: 12px;">
                                    <span t-field="doc.amount_total"
                                          t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>
            </table>

            <!-- 6. Amount in words -->
            <table style="width: 100%; margin: 8px 0 16px;" class="o_nw_avoid">
                <tr>
                    <td class="o_nw_band" style="padding: 9px 12px; font-size: 11px;">
                        <strong>In words:</strong>
                        <span t-out="doc.currency_id.amount_to_text(doc.amount_total)"/>
                    </td>
                </tr>
            </table>

            <!-- 7. Terms &amp; conditions -->
            <div class="o_nw_avoid" style="margin-bottom: 14px;">
                <div class="o_nw_sect" style="padding-bottom: 4px; margin-bottom: 8px;">
                    <span style="font-weight: 700; font-size: 12px; color: #161616;">Terms &amp; Conditions</span>
                </div>
                <ol style="font-size: 10.5px; line-height: 1.55; margin: 0; padding-left: 18px;">
                    <li>
                        This quotation is valid until
                        <t t-if="doc.validity_date"><span class="fw-bold" t-field="doc.validity_date"/>.</t>
                        <t t-else="">the date agreed by both parties.</t>
                    </li>
                    <li>Prices are quoted in <span t-field="doc.currency_id.name"/> and include VAT where applicable.</li>
                    <li>Delivery time and location as agreed between both parties.</li>
                    <li>
                        Payment terms:
                        <t t-if="doc.payment_term_id"><span t-field="doc.payment_term_id.name"/>.</t>
                        <t t-else="">as agreed between both parties.</t>
                    </li>
                    <li>Warranty and after-sales support as per the supplier's policy.</li>
                </ol>
                <t t-if="doc.note">
                    <div class="o_nw_label" style="margin-top: 8px;">Notes</div>
                    <div style="font-size: 10.5px;" t-field="doc.note"/>
                </t>
            </div>

            <!-- 8. Payment / bank details -->
            <t t-set="banks" t-value="doc.company_id.partner_id.bank_ids"/>
            <t t-if="banks" t-call="nwos_sale_report_image.nwos_payment_info"/>

            <!-- 9. Signature blocks (borderless, sign-on-the-line) -->
            <div class="o_nw_avoid" style="margin-top: 6px;">
                <div class="o_nw_muted" style="text-align: right; font-style: italic; font-size: 11px; margin-bottom: 8px;">
                    <t t-if="doc.company_id.city"><span t-field="doc.company_id.city"/>, </t>
                    <span t-field="doc.date_order" t-options='{"widget": "date"}'/>
                </div>
                <table style="width: 100%; table-layout: fixed; text-align: center; font-size: 11px;">
                    <tr>
                        <td style="width: 50%; padding: 0 12px 2px;" class="fw-bold">Customer</td>
                        <td style="width: 50%; padding: 0 12px 2px;" class="fw-bold">On behalf of the Seller</td>
                    </tr>
                    <tr>
                        <td class="o_nw_muted fst-italic" style="padding: 0 12px;">(Sign and print full name)</td>
                        <td class="o_nw_muted fst-italic" style="padding: 0 12px;">(Sign and print full name)</td>
                    </tr>
                    <tr>
                        <td style="height: 62px;"/>
                        <td style="height: 62px; vertical-align: bottom; padding-bottom: 4px;" class="fw-bold">
                            <span t-field="doc.user_id.name"/>
                        </td>
                    </tr>
                    <tr class="o_nw_signline">
                        <td style="padding-top: 3px;">&#160;</td>
                        <td style="padding-top: 3px;">&#160;</td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- ================= Repeating page footer ================= -->
        <div class="footer o_nw">
            <t t-out="nw_style"/>
            <table class="o_nw_footer o_nw_muted" style="width: 100%; font-size: 8.5px; padding-top: 3px;">
                <tr>
                    <td style="text-align: left;">
                        <span t-field="doc.company_id.name"/>
                        <t t-if="doc.company_id.vat">&#160;·&#160;Tax ID: <span t-field="doc.company_id.vat"/></t>
                        <t t-if="doc.company_id.phone">&#160;·&#160;Tel: <span t-field="doc.company_id.phone"/></t>
                    </td>
                    <td t-if="report_type == 'pdf'" style="text-align: right;" class="text-nowrap">
                        Page <span class="page"/> / <span class="topage"/>
                    </td>
                </tr>
            </table>
        </div>
    </template>

    <template id="report_saleorder_clean">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="nwos_sale_report_image.report_saleorder_clean_document"
                   t-lang="env.context.get('report_lang') or doc.partner_id.lang"/>
            </t>
        </t>
    </template>

    <!-- Pro-forma invoice: same clean layout, titled "Pro-forma Invoice". -->
    <template id="report_saleorder_proforma_clean">
        <t t-call="web.html_container">
            <t t-foreach="docs.with_context(proforma=True)" t-as="doc">
                <t t-call="nwos_sale_report_image.report_saleorder_clean_document"
                   t-lang="env.context.get('report_lang') or doc.partner_id.lang"/>
            </t>
        </t>
    </template>

</nwos>
