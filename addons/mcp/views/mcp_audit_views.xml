<?xml version="1.0" encoding="utf-8"?>
<nwos>
    <record id="mcp_audit_log_view_list" model="ir.ui.view">
        <field name="name">mcp.audit.log.list</field>
        <field name="model">mcp.audit.log</field>
        <field name="arch" type="xml">
            <list string="MCP Audit Logs" create="false" edit="false"
                decoration-success="status == 'success'" decoration-danger="status == 'error'">
                <field name="create_date"/>
                <field name="user_id"/>
                <field name="client_name" optional="show"/>
                <field name="model_name" optional="show"/>
                <field name="operation" optional="show"/>
                <field name="record_ids" optional="hide"/>
                <field name="status" widget="badge"/>
                <field name="duration_ms" optional="show"/>
                <field name="error_category" optional="hide"/>
                <field name="request_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="mcp_audit_log_view_form" model="ir.ui.view">
        <field name="name">mcp.audit.log.form</field>
        <field name="model">mcp.audit.log</field>
        <field name="arch" type="xml">
            <form string="MCP Audit Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group string="Request">
                            <field name="create_date"/>
                            <field name="user_id"/>
                            <field name="request_id"/>
                            <field name="client_name"/>
                            <field name="session_id"/>
                            <field name="ip_address"/>
                        </group>
                        <group string="Result">
                            <field name="status"/>
                            <field name="duration_ms"/>
                            <field name="error_category"/>
                            <field name="error_message"/>
                        </group>
                    </group>
                    <group string="Operation">
                        <field name="model_name"/>
                        <field name="operation"/>
                        <field name="record_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="mcp_audit_log_view_search" model="ir.ui.view">
        <field name="name">mcp.audit.log.search</field>
        <field name="model">mcp.audit.log</field>
        <field name="arch" type="xml">
            <search string="MCP Audit Logs">
                <field name="user_id"/>
                <field name="client_name"/>
                <field name="model_name"/>
                <field name="operation"/>
                <field name="request_id"/>
                <filter name="success" string="Successful" domain="[('status', '=', 'success')]"/>
                <filter name="errors" string="Errors" domain="[('status', '=', 'error')]"/>
                <separator/>
                <filter name="today" string="Today"
                    domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <group name="group_by">
                    <filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
                    <filter name="group_model" string="Model" context="{'group_by': 'model_name'}"/>
                    <filter name="group_operation" string="Operation" context="{'group_by': 'operation'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_day" string="Date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="mcp_audit_log_action" model="ir.actions.act_window">
        <field name="name">Audit Logs</field>
        <field name="res_model">mcp.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="mcp_audit_log_view_search"/>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No MCP requests have been audited yet</p>
            <p>Audit entries contain request metadata and outcomes, never business field values or binary payloads.</p>
        </field>
    </record>
</nwos>
