<?xml version="1.0" encoding="utf-8"?>
<nwos>
    <record id="res_config_settings_view_form_rfid_bod" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.rfid.bod</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="nwos_rfid_service.res_config_settings_view_form_rfid"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='rfid_operations']" position="inside">
                <setting string="Monthly BOD report recipients" company_dependent="1" help="Comma-separated email addresses that receive the previous month's Nextwaves Kit PDF report on the first day of each month.">
                    <field name="rfid_bod_recipient_emails" placeholder="bod@example.com, operations@example.com"/>
                </setting>
            </xpath>
        </field>
    </record>
</nwos>
