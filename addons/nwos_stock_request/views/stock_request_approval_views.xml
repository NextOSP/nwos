<?xml version="1.0" encoding="utf-8"?>
<nwos>
    <data>

        <!-- ============ Approval Rule ============ -->
        <record id="view_stock_request_approval_rule_form" model="ir.ui.view">
            <field name="name">stock.request.approval.rule.form</field>
            <field name="model">stock.request.approval.rule</field>
            <field name="arch" type="xml">
                <form string="Approval Rule">
                    <sheet>
                        <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger"
                                invisible="active"/>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="e.g. Over 10,000"/></h1>
                        </div>
                        <group>
                            <group string="Match When">
                                <label for="min_amount" string="Estimated total"/>
                                <div class="o_row">
                                    <field name="min_amount" class="oe_inline"/>
                                    <span>≤ total &lt;</span>
                                    <field name="max_amount" class="oe_inline"/>
                                    <field name="currency_id" invisible="1"/>
                                </div>
                                <field name="purpose"/>
                                <field name="warehouse_ids" widget="many2many_tags"/>
                                <field name="department_ids" widget="many2many_tags"/>
                            </group>
                            <group string="Options">
                                <field name="sequence"/>
                                <field name="active" widget="boolean_toggle"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <separator string="Approval Steps (in order)"/>
                        <field name="step_ids">
                            <list string="Steps" editable="bottom">
                                <field name="sequence" widget="handle"/>
                                <field name="name"/>
                                <field name="approver_type"/>
                                <field name="user_ids" widget="many2many_tags"
                                       invisible="approver_type != 'users'"
                                       required="approver_type == 'users'"/>
                                <field name="group_id"
                                       invisible="approver_type != 'group'"
                                       required="approver_type == 'group'"/>
                                <field name="manager_level"
                                       invisible="approver_type != 'manager'"/>
                                <field name="approval_mode"/>
                            </list>
                        </field>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_stock_request_approval_rule_list" model="ir.ui.view">
            <field name="name">stock.request.approval.rule.list</field>
            <field name="model">stock.request.approval.rule</field>
            <field name="arch" type="xml">
                <list string="Approval Rules">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="min_amount"/>
                    <field name="max_amount"/>
                    <field name="purpose"/>
                    <field name="currency_id" column_invisible="1"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </list>
            </field>
        </record>

        <record id="action_stock_request_approval_rule" model="ir.actions.act_window">
            <field name="name">Approval Rules</field>
            <field name="res_model">stock.request.approval.rule</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Define an approval rule</p>
                <p>Match requests by amount, purpose, warehouse or department, and
                   drive them through one or more approval steps.</p>
            </field>
        </record>

        <!-- ============ Auto-Approval ============ -->
        <record id="view_stock_request_approval_auto_form" model="ir.ui.view">
            <field name="name">stock.request.approval.auto.form</field>
            <field name="model">stock.request.approval.auto</field>
            <field name="arch" type="xml">
                <form string="Auto-Approval">
                    <sheet>
                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="e.g. Team leads under 500"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="user_ids" widget="many2many_tags"/>
                                <label for="max_amount"/>
                                <div class="o_row">
                                    <span>total &lt;</span>
                                    <field name="max_amount" class="oe_inline"/>
                                    <field name="currency_id" invisible="1"/>
                                </div>
                                <field name="scope"/>
                            </group>
                            <group>
                                <field name="sequence"/>
                                <field name="active" widget="boolean_toggle"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_stock_request_approval_auto_list" model="ir.ui.view">
            <field name="name">stock.request.approval.auto.list</field>
            <field name="model">stock.request.approval.auto</field>
            <field name="arch" type="xml">
                <list string="Auto-Approval" editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="user_ids" widget="many2many_tags"/>
                    <field name="max_amount"/>
                    <field name="scope"/>
                    <field name="currency_id" column_invisible="1"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                </list>
            </field>
        </record>

        <record id="action_stock_request_approval_auto" model="ir.actions.act_window">
            <field name="name">Auto-Approval</field>
            <field name="res_model">stock.request.approval.auto</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Add an auto-approval rule</p>
                <p>Let chosen users' requests be approved automatically below an amount —
                   the first step only, or the whole request.</p>
            </field>
        </record>

    </data>
</nwos>
