<?xml version="1.0" encoding="utf-8"?>
<nwos>
    <data>

        <record id="view_stock_request_form" model="ir.ui.view">
            <field name="name">stock.request.form</field>
            <field name="model">stock.request</field>
            <field name="arch" type="xml">
                <form string="Stock Request">
                    <header>
                        <button name="action_submit" string="Submit" type="object"
                                class="btn-primary" invisible="state != 'draft'"/>
                        <button name="action_approve" string="Approve" type="object"
                                class="btn-primary" invisible="not can_approve"/>
                        <button name="action_refuse" string="Refuse" type="object"
                                invisible="state != 'to_approve' or not can_approve"/>
                        <button name="action_generate_purchase" string="Generate Purchase"
                                type="object" class="btn-primary"
                                invisible="not (state == 'approved' or (state == 'done' and purchase_order_count == 0))"
                                groups="purchase.group_purchase_user"/>
                        <button name="action_cancel" string="Cancel" type="object"
                                invisible="state in ('done', 'cancel', 'refused')"/>
                        <button name="action_reset_to_draft" string="Reset to Draft"
                                type="object"
                                invisible="state not in ('refused', 'cancel')"/>
                        <field name="payment_state" widget="badge"
                               invisible="state != 'done'"
                               decoration-success="payment_state == 'paid'"
                               decoration-warning="payment_state in ('to_pay', 'partial')"
                               decoration-muted="payment_state == 'no_bill'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,to_approve,approved,done"/>
                        <field name="fulfillment_state" widget="statusbar"
                               invisible="state != 'done' or not fulfillment_state"
                               statusbar_visible="rfq,ordered,waiting,received"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_purchase_orders" type="object"
                                    class="oe_stat_button" icon="fa-shopping-cart"
                                    invisible="purchase_order_count == 0">
                                <field name="purchase_order_count" widget="statinfo"
                                       string="Purchases"/>
                            </button>
                            <button name="action_view_pickings" type="object"
                                    class="oe_stat_button" icon="fa-truck"
                                    invisible="picking_count == 0">
                                <field name="picking_count" widget="statinfo"
                                       string="Receipts"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="requester_id"
                                       readonly="state != 'draft'"/>
                                <field name="purpose" readonly="state not in ('draft', 'to_approve')"/>
                                <field name="warehouse_id" readonly="state != 'draft'"/>
                                <field name="department_id" readonly="state != 'draft'"/>
                                <field name="analytic_account_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="can_approve" invisible="1"/>
                            </group>
                            <group>
                                <field name="request_date" readonly="state != 'draft'"/>
                                <field name="date_required"/>
                                <field name="currency_id" readonly="state != 'draft'"
                                       groups="base.group_multi_currency"/>
                                <field name="approver_id" invisible="not approver_id"/>
                                <field name="approved_date" invisible="not approved_date"/>
                            </group>
                        </group>
                        <field name="refuse_reason" invisible="state != 'refused'"
                               readonly="1"/>
                        <notebook>
                            <page string="Items" name="items">
                                <field name="line_ids"
                                       readonly="state not in ('draft', 'to_approve')">
                                    <list string="Items" editable="bottom">
                                        <field name="allowed_uom_ids" column_invisible="1"/>
                                        <field name="product_id"
                                               width="280"
                                               options="{'no_quick_create': false}"/>
                                        <field name="name" width="240"/>
                                        <field name="product_qty"/>
                                        <field name="product_uom"
                                               groups="uom.group_uom"/>
                                        <field name="source_action"/>
                                        <field name="vendor_id"
                                               readonly="source_action != 'buy'"/>
                                        <field name="route_id" optional="hide"/>
                                        <field name="price_unit"/>
                                        <field name="price_subtotal"/>
                                        <field name="currency_id" column_invisible="1"/>
                                        <button name="action_create_product" type="object"
                                                icon="fa-plus-circle" title="Create Product from Spec"
                                                invisible="product_id"/>
                                    </list>
                                </field>
                                <group class="oe_subtotal_footer oe_right">
                                    <field name="estimated_total"/>
                                </group>
                            </page>
                            <page string="Approvals" name="approvals"
                                  invisible="state == 'draft' and not approval_ids">
                                <field name="approval_rule_id" readonly="1"
                                       invisible="not approval_rule_id"/>
                                <field name="current_approval_id" invisible="1"/>
                                <field name="approval_ids" readonly="1">
                                    <list string="Approval Steps"
                                          decoration-success="status == 'approved'"
                                          decoration-danger="status == 'rejected'"
                                          decoration-bf="is_current">
                                        <field name="sequence"/>
                                        <field name="name"/>
                                        <field name="approver_names" string="Approvers"/>
                                        <field name="approval_mode"/>
                                        <field name="approved_user_ids" widget="many2many_tags"
                                               string="Approved by"/>
                                        <field name="status" widget="badge"
                                               decoration-success="status == 'approved'"
                                               decoration-danger="status == 'rejected'"/>
                                        <field name="is_current" column_invisible="1"/>
                                        <field name="can_approve" column_invisible="1"/>
                                        <button name="action_approve_step" type="object"
                                                string="Approve" class="btn-link text-success"
                                                icon="fa-check" invisible="not can_approve"/>
                                        <button name="action_reject_step" type="object"
                                                string="Reject" class="btn-link text-danger"
                                                icon="fa-times" invisible="not can_approve"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notes" name="notes">
                                <field name="note" placeholder="Internal notes..."/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_stock_request_list" model="ir.ui.view">
            <field name="name">stock.request.list</field>
            <field name="model">stock.request</field>
            <field name="arch" type="xml">
                <list string="Stock Requests"
                      js_class="stock_request_dashboard_list"
                      decoration-muted="state in ('cancel', 'refused')"
                      decoration-info="state == 'to_approve'"
                      decoration-success="state == 'done'">
                    <field name="name"/>
                    <field name="requester_id"/>
                    <field name="purpose"/>
                    <field name="request_date"/>
                    <field name="date_required"/>
                    <field name="warehouse_id"/>
                    <field name="estimated_total" sum="Estimated Total"/>
                    <field name="currency_id" column_invisible="1"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="state" widget="badge"
                           decoration-info="state == 'to_approve'"
                           decoration-success="state in ('approved', 'done')"/>
                </list>
            </field>
        </record>

        <record id="view_stock_request_search" model="ir.ui.view">
            <field name="name">stock.request.search</field>
            <field name="model">stock.request</field>
            <field name="arch" type="xml">
                <search string="Stock Requests">
                    <field name="name"/>
                    <field name="requester_id"/>
                    <field name="line_ids" string="Product"
                           filter_domain="[('line_ids.product_id', 'ilike', self)]"/>
                    <filter string="My Requests" name="my"
                            domain="[('requester_id', '=', uid)]"/>
                    <filter string="Awaiting My Approval" name="awaiting"
                            domain="[('state', '=', 'to_approve'),
                                     ('approval_ids.status', '=', 'pending'),
                                     ('approval_ids.approver_ids', 'in', uid)]"/>
                    <separator/>
                    <filter string="Draft" name="draft"
                            domain="[('state', '=', 'draft')]"/>
                    <filter string="To Approve" name="to_approve"
                            domain="[('state', '=', 'to_approve')]"/>
                    <filter string="Approved" name="approved"
                            domain="[('state', '=', 'approved')]"/>
                    <filter string="Purchased" name="done"
                            domain="[('state', '=', 'done')]"/>
                    <group>
                        <filter string="Requester" name="grp_requester"
                                context="{'group_by': 'requester_id'}"/>
                        <filter string="Purpose" name="grp_purpose"
                                context="{'group_by': 'purpose'}"/>
                        <filter string="Status" name="grp_state"
                                context="{'group_by': 'state'}"/>
                        <filter string="Request Date" name="grp_date"
                                context="{'group_by': 'request_date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_stock_request" model="ir.actions.act_window">
            <field name="name">Stock Requests</field>
            <field name="res_model">stock.request</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_stock_request_search"/>
            <field name="context">{'search_default_my': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create your first stock request</p>
                <p>Request items for stock, office, a project or manufacturing.
                   Once approved, a buyer turns them into purchases.</p>
            </field>
        </record>

        <!-- Refuse wizard -->
        <record id="view_stock_request_refuse_form" model="ir.ui.view">
            <field name="name">stock.request.refuse.form</field>
            <field name="model">stock.request.refuse</field>
            <field name="arch" type="xml">
                <form string="Refuse Request">
                    <field name="request_id" invisible="1"/>
                    <group>
                        <field name="reason" placeholder="Why is this request refused?"/>
                    </group>
                    <footer>
                        <button name="action_confirm" string="Refuse" type="object"
                                class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</nwos>
