<?xml version="1.0" encoding="utf-8"?>
<nwos>

    <record model="res.groups.privilege" id="res_groups_privilege_helpdesk">
        <field name="name">Helpdesk</field>
        <field name="sequence">50</field>
        <field name="category_id" ref="base.module_category_services"/>
    </record>

    <record id="group_helpdesk_user" model="res.groups">
        <field name="name">User</field>
        <field name="comment">User: Can manage tickets assigned to them or their team.</field>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="privilege_id" ref="res_groups_privilege_helpdesk"/>
    </record>

    <record id="group_helpdesk_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="comment">Administrator: Can manage teams, stages, SLA policies and all tickets.</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="res_groups_privilege_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('helpdesk.group_helpdesk_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

<data noupdate="1">

    <record model="ir.rule" id="helpdesk_team_comp_rule">
        <field name="name">Helpdesk Team: multi-company</field>
        <field name="model_id" ref="model_helpdesk_team"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
    </record>

    <record model="ir.rule" id="helpdesk_ticket_comp_rule">
        <field name="name">Helpdesk Ticket: multi-company</field>
        <field name="model_id" ref="model_helpdesk_ticket"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
    </record>

</data>

</nwos>
