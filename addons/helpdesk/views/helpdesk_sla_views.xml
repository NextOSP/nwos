<?xml version="1.0" encoding="utf-8"?>
<nwos>

    <record id="view_helpdesk_sla_search" model="ir.ui.view">
        <field name="name">helpdesk.sla.search</field>
        <field name="model">helpdesk.sla</field>
        <field name="arch" type="xml">
            <search string="SLA Policies">
                <field name="name"/>
                <field name="team_id"/>
                <field name="stage_id"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Team" name="group_team" context="{'group_by': 'team_id'}"/>
                    <filter string="Target Stage" name="group_stage" context="{'group_by': 'stage_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_helpdesk_sla_list" model="ir.ui.view">
        <field name="name">helpdesk.sla.list</field>
        <field name="model">helpdesk.sla</field>
        <field name="arch" type="xml">
            <list string="SLA Policies">
                <field name="name"/>
                <field name="team_id"/>
                <field name="stage_id"/>
                <field name="priority"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" optional="show"/>
                <field name="time_days"/>
                <field name="time_hours"/>
                <field name="time_minutes" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_sla_form" model="ir.ui.view">
        <field name="name">helpdesk.sla.form</field>
        <field name="model">helpdesk.sla</field>
        <field name="arch" type="xml">
            <form string="SLA Policy">
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Urgent tickets solved in 4 hours"/></h1>
                    </div>
                    <group>
                        <group string="Criteria">
                            <field name="team_id"/>
                            <field name="priority"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="partner_ids" widget="many2many_tags"/>
                        </group>
                        <group string="Target">
                            <field name="stage_id"/>
                            <field name="exclude_stage_ids" widget="many2many_tags"/>
                            <label for="time_days" string="Within"/>
                            <div class="o_row">
                                <field name="time_days"/> days
                                <field name="time_hours"/> hours
                                <field name="time_minutes"/> minutes
                            </div>
                        </group>
                    </group>
                    <field name="description" placeholder="Explain the purpose of this policy..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_sla" model="ir.actions.act_window">
        <field name="name">SLA Policies</field>
        <field name="res_model">helpdesk.sla</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_helpdesk_sla_search"/>
    </record>

</nwos>
