<?xml version="1.0" encoding="utf-8"?>
<nwos>

    <record id="view_helpdesk_team_list" model="ir.ui.view">
        <field name="name">helpdesk.team.list</field>
        <field name="model">helpdesk.team</field>
        <field name="arch" type="xml">
            <list string="Helpdesk Teams">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="alias_email" string="Email Alias"/>
                <field name="open_ticket_count"/>
                <field name="closed_ticket_count"/>
                <field name="sla_success_rate" widget="percentage"/>
                <field name="avg_rating" widget="float" options="{'decimal_precision': 1}"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_team_form" model="ir.ui.view">
        <field name="name">helpdesk.team.form</field>
        <field name="model">helpdesk.team</field>
        <field name="arch" type="xml">
            <form string="Helpdesk Team">
                <sheet>
                    <field name="active" invisible="1"/>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tickets" type="object" class="oe_stat_button" icon="fa-ticket">
                            <field name="ticket_count" widget="statinfo" string="Tickets"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Customer Care"/></h1>
                    </div>
                    <group>
                        <group name="team">
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="member_ids" widget="many2many_avatar_user"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group name="email">
                            <label for="alias_name" string="Email Alias"/>
                            <div class="oe_inline" name="alias_def">
                                <field name="alias_id" invisible="1" required="0"/>
                                <field name="alias_name" placeholder="e.g. support" class="oe_inline"/>@<field name="alias_domain" class="oe_inline" readonly="1"/>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Assignment &amp; Stages" name="assignment">
                            <group>
                                <group string="Assignment">
                                    <field name="auto_assignment"/>
                                    <field name="assign_method" invisible="not auto_assignment"
                                           required="auto_assignment"/>
                                </group>
                                <group string="Stages">
                                    <field name="stage_ids" widget="many2many_tags"/>
                                </group>
                            </group>
                        </page>
                        <page string="SLA" name="sla">
                            <group>
                                <group>
                                    <field name="use_sla"/>
                                    <field name="resource_calendar_id" invisible="not use_sla"/>
                                </group>
                            </group>
                            <field name="sla_ids" invisible="not use_sla">
                                <list string="SLA Policies">
                                    <field name="name"/>
                                    <field name="stage_id"/>
                                    <field name="priority"/>
                                    <field name="time_days"/>
                                    <field name="time_hours"/>
                                    <field name="time_minutes"/>
                                </list>
                            </field>
                        </page>
                        <page string="Performance" name="performance">
                            <group>
                                <group>
                                    <field name="open_ticket_count"/>
                                    <field name="unassigned_ticket_count"/>
                                    <field name="urgent_ticket_count"/>
                                </group>
                                <group>
                                    <field name="closed_ticket_count"/>
                                    <field name="sla_success_rate" widget="percentage"/>
                                    <field name="avg_rating" widget="float" options="{'decimal_precision': 1}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe your team and its purpose..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_helpdesk_team_kanban" model="ir.ui.view">
        <field name="name">helpdesk.team.kanban</field>
        <field name="model">helpdesk.team</field>
        <field name="arch" type="xml">
            <kanban class="o_helpdesk_team_kanban">
                <templates>
                    <t t-name="card">
                        <div class="d-flex flex-column h-100">
                            <div class="d-flex justify-content-between">
                                <field name="name" class="fw-bold fs-5"/>
                            </div>
                            <div class="text-muted small" invisible="not alias_email">
                                <i class="fa fa-envelope-o me-1" title="Email Alias"/><field name="alias_email"/>
                            </div>
                            <div class="row mt-2">
                                <div class="col-6">
                                    <button type="object" name="action_view_tickets" class="btn btn-primary btn-sm">Tickets</button>
                                </div>
                            </div>
                            <div class="row mt-auto pt-3 text-center">
                                <div class="col-3">
                                    <span class="d-block fw-bold text-primary"><field name="open_ticket_count"/></span>
                                    <small>Open</small>
                                </div>
                                <div class="col-3">
                                    <span class="d-block fw-bold text-warning"><field name="unassigned_ticket_count"/></span>
                                    <small>Unassigned</small>
                                </div>
                                <div class="col-3">
                                    <span class="d-block fw-bold text-danger"><field name="urgent_ticket_count"/></span>
                                    <small>Urgent</small>
                                </div>
                                <div class="col-3">
                                    <span class="d-block fw-bold text-muted"><field name="failed_ticket_count"/></span>
                                    <small>Failed</small>
                                </div>
                            </div>
                            <div class="row mt-2 text-center">
                                <div class="col-6">
                                    <span class="text-success">Tickets Closed</span>
                                    <field name="closed_ticket_count"/>
                                </div>
                                <div class="col-6">
                                    <span class="text-success">Average Rating</span>
                                    <field name="avg_rating" widget="float" options="{'decimal_precision': 1}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_helpdesk_team" model="ir.actions.act_window">
        <field name="name">Teams</field>
        <field name="res_model">helpdesk.team</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

</nwos>
