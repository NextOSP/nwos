<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="web.AppLauncher">
        <div class="o_app_launcher o_action d-flex flex-column">
            <div class="o_app_launcher_header">
                <div>
                    <h1 class="o_app_launcher_title">All Apps</h1>
                </div>
                <div class="o_app_launcher_search">
                    <i class="fa fa-search" aria-hidden="true"/>
                    <input
                        t-ref="searchInput"
                        type="search"
                        class="o_input"
                        placeholder="Search apps"
                        t-att-value="state.query"
                        t-on-input="onSearch"
                    />
                </div>
            </div>
            <div class="o_app_launcher_sections" t-if="apps.length">
                <section
                    t-foreach="appSections"
                    t-as="section"
                    t-key="section.id"
                    class="o_app_launcher_section"
                >
                    <h2 class="o_app_launcher_section_title" t-esc="section.name"/>
                    <div class="o_app_launcher_grid">
                        <a
                            t-foreach="section.apps"
                            t-as="app"
                            t-key="app.id"
                            class="o_app_launcher_app"
                            t-att-href="getAppHref(app)"
                            t-att-data-menu-xmlid="app.xmlid"
                            t-on-click.prevent="() => this.openApp(app)"
                        >
                            <span class="o_app_launcher_icon">
                                <img t-att-src="app.webIconData || '/web/static/img/default_icon_app.png'" t-att-alt="app.name"/>
                            </span>
                            <span class="o_app_launcher_name" t-esc="app.name"/>
                        </a>
                    </div>
                </section>
            </div>
            <div class="o_app_launcher_empty" t-else="">
                <t t-if="hasQuery">No matching apps</t>
                <t t-else="">No apps available</t>
            </div>
        </div>
    </t>

</templates>
